# Virtual environments
.venv/
venv/
env/

# uv
# (Do NOT ignore .python-version — you want that committed)
# (Do NOT ignore uv.lock — you want that committed too, for reproducibility)

# Python bytecode/cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Distribution / build artifacts
build/
dist/
*.egg-info/
*.egg

# Environment / secrets
.env
.env.local

# IDE/editor clutter
.vscode/
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db

# Jupyter checkpoints (if you use notebooks)
.ipynb_checkpoints/

# Test/coverage output
.pytest_cache/
.coverage
htmlcov/